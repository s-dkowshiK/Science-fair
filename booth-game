.push-s{color:#A32D2D;background:#FCEBEB}
.push-h{color:#27500A;background:#EAF3DE}

/* Comparison */
.comparison{display:flex;gap:14px;flex-wrap:wrap}
.comp-card{flex:1;min-width:170px;border:2px solid #D3D1C7;
           border-radius:12px;padding:16px 18px}
.comp-card.match{border-color:#1D9E75;background:#F0FBF6}
.comp-card.mismatch{border-color:#E24B4A;background:#FEF6F6}
.comp-card.neutral{border-color:#B4B2A9;background:#F9F8F5}
.comp-label{font-size:11px;font-weight:700;color:#888;
            text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.comp-value{font-size:20px;font-weight:600;color:#2C2C2A;margin-bottom:4px}
.comp-sub{font-size:12px;color:#5F5E5A;margin-bottom:10px}
.comp-icon{font-size:26px;font-weight:700}
.ic-m{color:#1D9E75}
.ic-x{color:#E24B4A}
.ic-n{color:#888}

/* Outcome banner */
.outcome-banner{padding:14px 22px;border-bottom:0.5px solid #E8E6DF}
.outcome-hl{font-size:16px;font-weight:700;margin-bottom:3px}
.outcome-sub{font-size:13px;opacity:.85}
.o-correct{background:#EAF3DE;color:#27500A}
.o-wrong{background:#FCEBEB;color:#A32D2D}

/* Gene table — unchanged per spec */
.gene-hint{font-size:12px;color:#B4B2A9;margin-bottom:12px;line-height:1.5}
table{width:100%;border-collapse:collapse;font-size:12px}
th{padding:7px 9px;text-align:left;font-size:10px;font-weight:600;
   color:#888;text-transform:uppercase;background:#F9F8F5;
   border-bottom:1px solid #D3D1C7}
td{padding:7px 9px;border-bottom:0.5px solid #E8E6DF}
tr:last-child td{border-bottom:none}
.gsym{font-family:monospace;font-weight:700;color:#2C2C2A;white-space:nowrap}
.gplain{font-weight:600;color:#3C3489}
.grole{color:#5F5E5A;max-width:190px}
.zp{color:#A32D2D;font-weight:700}
.zn{color:#0C447C;font-weight:700}
.bar-t{width:90px;height:7px;background:#F1EFE8;border-radius:4px;
       overflow:hidden;display:inline-block;vertical-align:middle}
.bar-s{height:100%;border-radius:4px;background:#E24B4A;display:block}
.bar-h{height:100%;border-radius:4px;background:#1D9E75;display:block}
.dir-s{color:#A32D2D;font-size:11px;font-weight:600}
.dir-h{color:#27500A;font-size:11px;font-weight:600}
.imp-cell{color:#888;text-align:right}

/* Summary */
.summary{background:#fff;border:0.5px solid #D3D1C7;border-radius:16px;
         overflow:hidden;margin-bottom:22px;display:none;
         box-shadow:0 2px 8px rgba(0,0,0,.07)}
.sum-head{background:#2C2C2A;padding:16px 22px}
.sum-head h2{font-size:18px;font-weight:600;color:#fff}
.sum-head p{font-size:13px;color:#888;margin-top:3px}
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);
           border-bottom:0.5px solid #E8E6DF}
.stat-cell{padding:16px 20px;border-right:0.5px solid #E8E6DF}
.stat-cell:last-child{border-right:none}
.stat-label{font-size:12px;color:#888;margin-bottom:5px}
.stat-num{font-size:26px;font-weight:600}
.stat-sub{font-size:13px;color:#888}
.log-wrap{padding:18px 22px}
</style>
</head>
<body>

<h1>AutophagyNet \u00b7 Booth</h1>
<p class="subtitle">Presenter mode \u2014 pick a patient card and reveal the autophagy analysis</p>

<div id="registry" class="registry"></div>

<div class="controls">
  <div class="ctrl-group">
    <span class="ctrl-label">Patient card</span>
    <select id="cardSel"></select>
  </div>
  <button class="btn btn-primary" onclick="showCard()">Show results</button>
  <button class="btn btn-warn"    onclick="showSummary()">Session summary</button>
  <button class="btn btn-sec"     onclick="resetSession()">Reset</button>
</div>

<div class="dash" id="dash"></div>
<div class="summary" id="summary"></div>

<script>
const CARDS = CARDS_JSON_PLACEHOLDER;
let session = {total:0, correct:0, log:[]};

function buildRegistry(){
  const reg = document.getElementById('registry');
  const sel = document.getElementById('cardSel');
  CARDS.forEach(c => {
    const bioHtml = Object.entries(c.bio).map(([k,v])=>
      `<div class="bio-row"><span class="bio-l">${k}</span>
       <span class="bio-v">${v}</span></div>`
    ).join('') || '<div style="font-size:11px;color:#B4B2A9;padding:4px 0">No bio data available</div>';
    reg.innerHTML += `
      <div class="reg-card">
        <div class="reg-head">
          <span class="reg-num">Card #${c.cardNum}</span>
          <span class="reg-id">${c.sampleId.slice(0,12)}</span>
        </div>
        <div class="reg-ds"><strong>${c.dataset}</strong><br>${c.tissue}</div>
        <div class="reg-bio">${bioHtml}</div>
      </div>`;
    const age  = c.bio['Age']||'';
    const sex  = c.bio['Sex']||'';
    const hint = [age,sex].filter(Boolean).join(' \u00b7 ');
    const opt  = document.createElement('option');
    opt.value  = c.cardNum;
    opt.textContent = `Card #${c.cardNum}${hint?' \u2014 '+hint:''}`;
    sel.appendChild(opt);
  });
}

function showCard(){
  const num  = parseInt(document.getElementById('cardSel').value);
  const card = CARDS.find(c=>c.cardNum===num);
  if(!card) return;
  session.total++;
  const match = card.modelPredSick === card.groundTruthSick;
  if(match) session.correct++;
  session.log.push({cardNum:card.cardNum, sampleId:card.sampleId,
    modelLabel:card.modelPredSick?'Sick':'Healthy',
    truthLabel:card.groundTruthLabel, match});
  renderDash(card, match);
}

function renderDash(card, match){
  const el = document.getElementById('dash');
  el.style.display='block';
  document.getElementById('summary').style.display='none';

  // demo items — exclude Sample source (shown separately in its own line)
  const demoEntries = Object.entries(card.bio).filter(([k])=>k!=='Sample source');
  const demoItems = demoEntries.map(([k,v])=>
    `<span class="demo-item"><strong>${k}:</strong> ${v}</span>`
  ).join('') || '<span class="demo-item" style="color:#888">No demographics available</span>';
  const sampleSource = card.bio['Sample source'] || card.tissue || '';

  const r       = card.reasoning;
  const sp      = r.sickPct;
  const hp      = r.healthyPct;

  const voteBar = `
    <div class="vote-bar-wrap">
      <div class="vote-label-row">
        <span class="lbl-sick">Toward disease &nbsp;${sp}%</span>
        <span class="lbl-healthy">${hp}% &nbsp;Toward healthy</span>
      </div>
      <div class="vote-track">
        <div class="vote-sick"  style="width:${sp}%">${sp>12?sp+'%':''}</div>
        <div class="vote-healthy">${hp>12?hp+'%':''}</div>
      </div>
      <div class="vote-counts">
        <span>${r.geneCount.sick} gene${r.geneCount.sick!==1?'s':''} pointing toward disease</span>
        <span>${r.geneCount.healthy} gene${r.geneCount.healthy!==1?'s':''} pointing toward healthy</span>
      </div>
    </div>`;

  const driverCards = r.topDrivers.map((d,i)=>{
    const zc  = d.zScore>0?'zpos':'zneg';
    const za  = d.zScore>0?'\u2191':'\u2193';
    const pc  = d.pushesSick?'push-s':'push-h';
    const pt  = d.pushesSick?'\u2191 Points toward disease':'\u2193 Points toward healthy';
    const rk  = ['Top driver','2nd driver','3rd driver'][i];
    return `<div class="driver-card">
      <div class="driver-rank">${rk}</div>
      <div class="driver-gene">${d.gene}</div>
      <div class="driver-plain">${d.plainName}</div>
      <div class="driver-role">${d.plainRole}</div>
      <div class="driver-z ${zc}">${za} z\u202f=\u202f${Math.abs(d.zScore)}</div>
      <div class="driver-push ${pc}">${pt}</div>
    </div>`;
  }).join('');

  function compCard(label,value,sub,cls,iconType){
    const ic = iconType==='match'?'ic-m':iconType==='mismatch'?'ic-x':'ic-n';
    const sym= iconType==='match'?'\u2713':iconType==='mismatch'?'\u2717':'\u2014';
    return `<div class="comp-card ${cls}">
      <div class="comp-label">${label}</div>
      <div class="comp-value">${value}</div>
      <div class="comp-sub">${sub}</div>
      <div class="comp-icon ${ic}">${sym}</div>
    </div>`;
  }

  const modelCard = compCard(
    'AI model prediction',
    card.modelPredSick?'Sick':'Healthy',
    'Confidence: '+card.modelConfidence+'%',
    match?'match':'mismatch', match?'match':'mismatch'
  );
  const truthCard = compCard(
    'Confirmed diagnosis',
    card.groundTruthLabel,
    'Dataset: '+card.dataset,
    'neutral','neutral'
  );

  const outCls = match?'o-correct':'o-wrong';
  const outHL  = match?'AI model matches confirmed diagnosis'
                      :'AI model does not match confirmed diagnosis';
  const outSub = match
    ?'The autophagy gene signature correctly identified this patient.'
    :'The autophagy gene signature gave a different answer from the clinical record \u2014 worth discussing why.';

  const geneRows = card.geneBreakdown.map(b=>{
    const zc = b.zScore>0?'zp':'zn';
    const za = b.zScore>0?'\u2191':'\u2193';
    const bc = b.pushesSick?'bar-s':'bar-h';
    const dc = b.pushesSick?'dir-s':'dir-h';
    const dt = b.pushesSick?'\u2191 Toward disease':'\u2193 Toward healthy';
    return `<tr>
      <td><span class="gsym">${b.gene}</span></td>
      <td><span class="gplain">${b.plainName}</span></td>
      <td class="grole">${b.plainRole}</td>
      <td><span class="${zc}">${za} ${Math.abs(b.zScore)}</span></td>
      <td><span class="bar-t"><span class="${bc}" style="width:${b.pctBar}%"></span></span></td>
      <td><span class="${dc}">${dt}</span></td>
      <td class="imp-cell">${b.importance}%</td>
    </tr>`;
  }).join('');

  // ── verbose bullet points for reasoning section ──────────────────────
  const bulletData = [
    {
      dotCls: r.sickPct >= 50 ? 'bullet-dot-sick' : 'bullet-dot-healthy',
      text: `<strong>${r.sickPct >= 50 ? 'Most genes pointed toward disease' : 'Most genes pointed toward healthy'}.</strong>
             Out of ${r.geneCount.sick + r.geneCount.healthy} autophagy genes examined,
             <strong>${r.geneCount.sick}</strong> pointed toward disease and
             <strong>${r.geneCount.healthy}</strong> pointed toward healthy.
             The disease-pointing genes carried <strong>${r.sickPct}%</strong> of the combined signal weight.`
    },
    {
      dotCls: 'bullet-dot-neutral',
      text: `<strong>The strongest driver was ${r.topDrivers[0]?.gene} (${r.topDrivers[0]?.plainName}).</strong>
             This gene's activity level was
             ${r.topDrivers[0]?.zScore > 0 ? 'higher than average' : 'lower than average'}
             (activity level = ${r.topDrivers[0]?.zScore > 0 ? '+' : ''}${r.topDrivers[0]?.zScore})
             — which the model interprets as
             ${r.topDrivers[0]?.pushesSick ? 'a sign of disease. ' : 'a healthy signal. '}
             ${r.topDrivers[0]?.plainRole}.`
    },
    {
      dotCls: 'bullet-dot-neutral',
      text: `<strong>The second driver was ${r.topDrivers[1]?.gene} (${r.topDrivers[1]?.plainName}).</strong>
             Activity level = ${r.topDrivers[1]?.zScore > 0 ? '+' : ''}${r.topDrivers[1]?.zScore},
             pushing ${r.topDrivers[1]?.pushesSick ? 'toward disease' : 'toward healthy'}.
             ${r.topDrivers[1]?.plainRole}.`
    },
    {
      dotCls: 'bullet-dot-neutral',
      text: `<strong>Confidence: ${card.modelConfidence}%.</strong>
             ${card.modelConfidence >= 75
               ? 'The model was highly confident in this prediction — the gene pattern was clear and consistent.'
               : card.modelConfidence >= 60
                 ? 'The model had moderate confidence. The gene pattern showed a lean in one direction but some conflicting signals were present.'
                 : 'The model had low confidence. The gene signals were mixed and borderline, making this a difficult case.'}`
    },
  ];

  const bulletsHtml = `<ul class="reasoning-bullets">${
    bulletData.map(b => `<li>
      <span class="bullet-dot ${b.dotCls}"></span>
      <span>${b.text}</span>
    </li>`).join('')
  }</ul>`;

  // ── mismatch explanation (only shown when model is wrong) ─────────────
  const mismatchHtml = !match ? `
    <div class="reasoning-mismatch">
      <div class="mismatch-title">\u26a0 Why might the model have been wrong?</div>
      <ul class="mismatch-bullets">
        <li>Autophagy gene signals in blood don't always perfectly reflect what is happening in the affected organ (such as the brain). A patient can show disease in one tissue while their blood gene pattern looks relatively normal.</li>
        <li>The model was trained to detect a binary sick/healthy pattern across multiple diseases. Some individual patients fall in a grey zone — particularly those with early-stage disease, MCI (Mild Cognitive Impairment), or conditions that overlap biologically.</li>
        <li>Gene expression measured from blood is influenced by many factors beyond disease: age, medications, inflammation from unrelated causes, and even time of day of the blood draw. These can mask or mimic disease signals.</li>
        <li>The Random Forest model uses population-level gene importance. For this specific patient, their individual gene pattern may be unusual even within their disease group — which is exactly what makes personalised medicine so challenging.</li>
      </ul>
    </div>` : '';

  el.innerHTML = `
    <div class="dash-header">
      <span class="card-badge">Card #${card.cardNum}</span>
      <span class="dash-title">Sample&nbsp;${card.sampleId}</span>
      <span class="pill">${card.dataset}</span>
    </div>

    <div class="demo-band">
      <div class="demo-lbl">Patient demographics</div>
      ${demoItems}
      <div style="width:100%;margin-top:8px;padding-top:8px;
                  border-top:0.5px solid #E8E6DF;font-size:13px;color:#5F5E5A">
        <strong style="color:#2C2C2A">Sample source:</strong> ${sampleSource}
      </div>
    </div>

    <div class="section">
      <div class="sec-label">AI model prediction vs confirmed diagnosis</div>
      <div class="comparison">${modelCard}${truthCard}</div>
    </div>

    <div class="outcome-banner ${outCls}">
      <div class="outcome-hl">${outHL}</div>
      <div class="outcome-sub">${outSub}</div>
    </div>

    <div class="section">
      <div class="sec-label">How the AI model made its decision</div>
      <div class="reasoning-narrative">${r.narrative}</div>
      ${bulletsHtml}
      ${voteBar}
      <div style="font-size:13px;font-weight:600;color:#5F5E5A;
                  margin-bottom:10px;margin-top:4px">
        Top 3 genes driving this decision
      </div>
      <div class="top-drivers">${driverCards}</div>
      ${mismatchHtml}
    </div>

    <div class="section">
      <div class="sec-label">Full gene breakdown</div>
      <div class="gene-hint">
        Red bar = pushing toward disease &nbsp;\u00b7&nbsp;
        Green bar = pushing toward healthy &nbsp;\u00b7&nbsp;
        Signal strength = how much the AI relied on this gene for this patient &nbsp;\u00b7&nbsp;
        Model weight = how important this gene is across all patients
      </div>
      <div style="overflow-x:auto">
        <table>
          <thead><tr>
            <th>Gene</th><th>Plain name</th><th>Role</th>
            <th>Activity level</th><th>Signal strength</th>
            <th>Direction</th><th>Model weight</th>
          </tr></thead>
          <tbody>${geneRows}</tbody>
        </table>
      </div>
    </div>

    <div style="padding:10px 22px;background:#F9F8F5;display:flex;
                align-items:center;border-top:0.5px solid #E8E6DF">
      <span style="font-size:12px;color:#888">
        Card #${card.cardNum} \u00b7 ${card.dataset} \u00b7
        ${session.total} card${session.total!==1?'s':''} shown this session
      </span>
    </div>`;
}

function showSummary(){
  const el = document.getElementById('summary');
  document.getElementById('dash').style.display='none';
  el.style.display='block';
  if(session.total===0){
    el.innerHTML=`<div class="sum-head"><h2>No cards shown yet.</h2></div>`;
    return;
  }
  const pct = Math.round(session.correct/session.total*100);
  const logRows = session.log.map(e=>{
    const ic=e.match?'\u2713':'\u2717';
    const cc=e.match?'#27500A':'#A32D2D';
    return `<tr>
      <td style="color:#888">#${e.cardNum}</td>
      <td style="font-family:monospace;font-size:11px;color:#5F5E5A">${e.sampleId.slice(0,16)}</td>
      <td>${e.modelLabel}</td>
      <td>${e.truthLabel}</td>
      <td style="text-align:center;font-weight:700;color:${cc}">${ic}</td>
    </tr>`;
  }).join('');
  el.innerHTML=`
    <div class="sum-head">
      <h2>Session summary</h2>
      <p>${session.total} cards shown \u00b7 AutophagyNet Booth</p>
    </div>
    <div class="stat-grid">
      <div class="stat-cell">
        <div class="stat-label">Cards shown</div>
        <div class="stat-num">${session.total}</div>
      </div>
      <div class="stat-cell">
        <div class="stat-label">AI model correct</div>
        <div class="stat-num" style="color:#185FA5">
          ${session.correct}
          <span class="stat-sub"> / ${session.total} (${pct}%)</span>
        </div>
      </div>
      <div class="stat-cell">
        <div class="stat-label">AI model wrong</div>
        <div class="stat-num" style="color:#A32D2D">
          ${session.total-session.correct}
          <span class="stat-sub"> / ${session.total}</span>
        </div>
      </div>
    </div>
    <div class="log-wrap">
      <div style="font-size:10px;font-weight:500;color:#888;
                  text-transform:uppercase;letter-spacing:.06em;
                  margin-bottom:10px">Session log</div>
      <table>
        <thead><tr>
          <th>#</th><th>Sample</th><th>AI predicted</th>
          <th>Confirmed diagnosis</th><th>Result</th>
        </tr></thead>
        <tbody>${logRows}</tbody>
      </table>
    </div>`;
}

function resetSession(){
  session={total:0,correct:0,log:[]};
  document.getElementById('dash').style.display='none';
  document.getElementById('summary').style.display='none';
}

buildRegistry();
</script>
</body>
</html>"""

html_output = HTML_TEMPLATE.replace('CARDS_JSON_PLACEHOLDER', cards_json)

output_file = "booth_game.html"
with open(output_file, "w", encoding="utf-8") as f:
    f.write(html_output)

size_kb = len(html_output.encode()) // 1024
print(f"\nSaved: {output_file}  ({size_kb} KB)")
print("Open in Chrome. No internet, no Python needed.")
display(FileLink(output_file, result_html_prefix="Download: "))

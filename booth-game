# ── Gene direction: does HIGH expression push toward sick? ────────────────────
def gene_directions(X_corr, y, gene_cols):
    df           = X_corr[gene_cols].copy()
    df['_y']     = y
    sick_mean    = df[df['_y'] == 1][gene_cols].mean()
    healthy_mean = df[df['_y'] == 0][gene_cols].mean()
    return (sick_mean > healthy_mean).to_dict()

# ── Gene breakdown per sample ─────────────────────────────────────────────────
def build_gene_breakdown(sample_id, X_corr, rf, gene_cols, directions):
    if sample_id not in X_corr.index:
        return []
    importances = rf.feature_importances_
    top_idx     = np.argsort(importances)[::-1][:TOP_GENES]
    row         = X_corr.loc[sample_id]
    tmp = []
    for idx in top_idx:
        gene         = gene_cols[idx]
        imp          = float(importances[idx])
        z            = float(row.get(gene, 0.0))
        high_is_sick = bool(directions.get(gene, True))
        pushes_sick  = (z > 0) if high_is_sick else (z < 0)
        strength     = abs(z) * imp
        info         = GENE_PLAIN.get(gene, (gene, ''))
        tmp.append({
            'gene':       gene,
            'plainName':  info[0],
            'plainRole':  info[1],
            'zScore':     round(z, 2),
            'pushesSick': pushes_sick,
            'importance': round(imp * 100, 1),
            'strength':   strength,
        })
    max_str = max((b['strength'] for b in tmp), default=1) or 1
    for b in tmp:
        b['pctBar'] = int(min(100, b['strength'] / max_str * 100))
        del b['strength']
    return tmp

# ── Reasoning summary ─────────────────────────────────────────────────────────
def build_reasoning(gene_breakdown, model_pred_sick):
    sick_w    = sum(b['importance'] * b['pctBar'] / 100
                    for b in gene_breakdown if b['pushesSick'])
    healthy_w = sum(b['importance'] * b['pctBar'] / 100
                    for b in gene_breakdown if not b['pushesSick'])
    total_w   = sick_w + healthy_w or 1

    sick_pct    = int(round(sick_w / total_w * 100))
    healthy_pct = 100 - sick_pct
    sick_count    = sum(1 for b in gene_breakdown if b['pushesSick'])
    healthy_count = len(gene_breakdown) - sick_count

    top3     = sorted(gene_breakdown, key=lambda b: b['pctBar'], reverse=True)[:3]
    top_gene = top3[0] if top3 else None

    if top_gene:
        direction = "elevated" if top_gene['zScore'] > 0 else "suppressed"
        push      = "toward disease" if top_gene['pushesSick'] else "toward healthy"
        if model_pred_sick:
            narrative = (
                f"The AI model predicted this patient is sick. "
                f"{sick_count} of {len(gene_breakdown)} genes pushed toward disease, "
                f"carrying {sick_pct}% of the combined signal weight. "
                f"The strongest driver was {top_gene['gene']} ({top_gene['plainName']}), "
                f"which was {direction} (activity level = {top_gene['zScore']:+.1f}) "
                f"and pushed {push}."
            )
        else:
            narrative = (
                f"The AI model predicted this patient is healthy. "
                f"{healthy_count} of {len(gene_breakdown)} genes pushed toward healthy, "
                f"carrying {healthy_pct}% of the combined signal weight. "
                f"The strongest driver was {top_gene['gene']} ({top_gene['plainName']}), "
                f"which was {direction} (activity level = {top_gene['zScore']:+.1f}) "
                f"and pushed {push}."
            )
    else:
        narrative = "Insufficient gene data to generate a narrative."

    return {
        'sickPct':     sick_pct,
        'healthyPct':  healthy_pct,
        'topDrivers':  top3,
        'narrative':   narrative,
        'geneCount':   {'sick': sick_count, 'healthy': healthy_count},
    }

# ── Ground truth lookups ──────────────────────────────────────────────────────
def build_gt_lookup(full_df, gse_cache, datasets_config, PHENO_CONFIG):
    binary = {
        sid: ('Sick' if full_df.loc[sid, 'Status'] == 1 else 'Healthy')
        for sid in full_df.index
    }
    label = {}
    for ds in datasets_config:
        cfg     = PHENO_CONFIG[ds['id']]
        gse_obj = gse_cache.get(ds['id'])
        if gse_obj is None:
            continue
        meta = gse_obj.phenotype_data
        if cfg['status_col'] in meta.columns:
            for sid, val in meta[cfg['status_col']].items():
                label[sid] = str(val).strip()
    return binary, label


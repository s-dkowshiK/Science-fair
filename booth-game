# ── Translate raw GEO diagnosis labels into plain English ─────────────────────
def translate_diagnosis(raw):
    """Convert raw GEO status strings to plain-English display labels."""
    mapping = {
        'ad':                          "Alzheimer's Disease",
        'alzheimer':                   "Alzheimer's Disease",
        "alzheimer's":                 "Alzheimer's Disease",
        'mci':                         "MCI (Mild Cognitive Impairment)",
        'borderline mci':              "Borderline MCI (Mild Cognitive Impairment)",
        'ctl':                         "Healthy volunteer",
        'ctl to ad':                   "Healthy volunteer (converted to AD)",
        'control':                     "Healthy volunteer",
        'healthy':                     "Healthy volunteer",
        'sle':                         "Lupus (SLE)",
        'other':                       "Other",
    }
    return mapping.get(raw.lower().strip(), raw)

